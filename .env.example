# Required: your bot's token from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# Required: the ID of the role that marks someone as a slug
# Right-click the role in Discord (with Developer Mode on) to copy the ID
SLUG_ROLE_ID=123456789012345678

# Optional: restricts slash command registration to one guild for instant updates.
# Remove or leave blank to register commands globally (can take up to 1 hour).
GUILD_ID=123456789012345678
